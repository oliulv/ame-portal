# ============================================================
# Copy this file to .env.local and fill in the values.
# Ask the team lead for dev credentials.
# NEVER commit .env.local — it's gitignored.
# ============================================================

# Clerk (use TEST keys from Clerk dashboard → Development instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER_DOMAIN=https://your-dev-instance.clerk.accounts.dev

# Convex (use DEV deployment from Convex dashboard)
CONVEX_DEPLOYMENT=dev:your-dev-slug
NEXT_PUBLIC_CONVEX_URL=https://your-dev-slug.eu-west-1.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-dev-slug.eu-west-1.convex.site

# Clone script (bun clone:prod) — get deploy keys from Convex dashboard > Settings > Deploy Keys
# DO NOT use CONVEX_DEPLOY_KEY — the Convex CLI reserves that name
CLONE_DEV_DEPLOY_KEY=dev:your-dev-slug|...
CLONE_PROD_URL=https://your-prod-slug.eu-west-1.convex.cloud
CLONE_PROD_DEPLOY_KEY=prod:your-prod-slug|...

# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email
RESEND_API_KEY=re_...
FROM_EMAIL="Accelerate ME <hello@ameportal.com>"

# Logging
LOG_SAMPLE_RATE=1.0

# Supabase partner credentials
SUPABASE_PARTNER_API_KEY=sb_partner_...

# Xero reimbursement flow emails
XERO_BILLS_EMAIL = bills...@xerofiles.com
XERO_RECEIPTS_EMAIL = xero...@xerofiles.com

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=<your-posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Openrouter
OPENROUTER_API_KEY=sk-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=3f...
TWILIO_SMS_FROM=+44...
TWILIO_VERIFY_SERVICE_SID=VA...

# GitHub App (create at github.com/settings/apps)
NEXT_PUBLIC_GITHUB_APP_CLIENT_ID=Iv1.abc123...
GITHUB_APP_CLIENT_ID=Iv1.abc123...
GITHUB_APP_CLIENT_SECRET=abc123...
# The App's public URL slug (from github.com/apps/<slug>). Used to drive the
# install-and-authorize flow so founders install the App on their private
# repos in a single click. The App must have "Request user authorization
# (OAuth) during installation" enabled so the callback still receives `code`.
GITHUB_APP_SLUG=acc-os-tracking

# Apify (apify.com — Starter plan, ~$10/mo for social scraping)
APIFY_API_TOKEN=apify_api_...
