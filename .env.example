# ============================================================
# Copy this file to .env.local and fill in the values.
# Ask the team lead for dev credentials.
# NEVER commit .env.local — it's gitignored.
# ============================================================

# Clerk (use TEST keys from Clerk dashboard → Development instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER_DOMAIN=https://your-dev-instance.clerk.accounts.dev

# Convex (use DEV deployment from Convex dashboard)
CONVEX_DEPLOYMENT=dev:your-dev-slug
NEXT_PUBLIC_CONVEX_URL=https://your-dev-slug.eu-west-1.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-dev-slug.eu-west-1.convex.site

# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email
RESEND_API_KEY=re_...
FROM_EMAIL="Accelerate ME <hello@ameportal.com>"

# Logging
LOG_SAMPLE_RATE=1.0

# Supabase partner credentials
SUPABASE_PARTNER_API_KEY=sb_partner_...

# Xero reimbursement flow emails
XERO_BILLS_EMAIL = bills...@xerofiles.com
XERO_RECEIPTS_EMAIL = xero...@xerofiles.com

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=<your-posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Openrouter
OPENROUTER_API_KEY=sk-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=3f...
TWILIO_SMS_FROM=+44...
TWILIO_VERIFY_SERVICE_SID=VA...
