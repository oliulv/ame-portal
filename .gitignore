/.next/
/out/
.next
.swc

# production
/build
/dist

# misc
*.pem
*.key
*.crt
*.cert
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# Claude Code
.claude/

# Supabase
.supabase/
supabase/.temp/
supabase/.branches/

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
*.code-workspace

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Cache directories
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.cache

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# Clone script run logs
clone-runs/

# Database
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# Secrets and credentials
secrets/
.secrets/
credentials.json
service-account*.json
*-credentials.json
*.p12
*.pfx

# Local development
.local/
local/
*.local

# Build artifacts
*.min.js
*.min.css
*.map
source-map-resources/

# Package manager locks (optional - uncomment if you don't want to commit)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# bun.lockb

# Markdown documentation files (ignore all except essential ones)
*.md
!README.md
!DEPLOYMENT.md
!ADMIN_SETUP.md
!INTEGRATIONS_SETUP.md
!CLAUDE.md
.gstack/
